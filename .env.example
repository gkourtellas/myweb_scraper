# Copy to .env and adjust on the server:
#   cp .env.example .env

# How often the scraper runs main.py (seconds). 3600 = hourly.
SCRAPE_INTERVAL_SECONDS=3600

# Host path mounted into the scraper container for kingbet/sentragoal JSON output.
MATCHBOT_HOST_DIR=/home/gk/matchbot

# Path inside the container (usually leave as /matchbot).
MATCHBOT_OUTPUT_DIR=/matchbot

# Telegram credentials file inside the project (default: tginfo.txt in repo root).
TGINFO_PATH=/app/tginfo.txt

# Published ports (host side).
STATUS_PORT=8001
HOMEPAGE_PORT=6969
