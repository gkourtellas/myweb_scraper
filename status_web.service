[Unit]
Description=MyWeb Scraper Status Console
After=network.target

[Service]
Type=simple
User=gk
WorkingDirectory=/home/gk/myweb_scraper
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/gk/myweb_scraper/venv/bin/python3 /home/gk/myweb_scraper/status_web.py 8001
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
